| WHERE message == "42" OR message == "Connected to 10.1.0.1!"
| FORK (EVAL unmapped_mv = MV_SORT(unmapped_mv))
       (WHERE message == "42")
| KEEP _fork, message, unmapped_mv
| SORT _fork, message
;

