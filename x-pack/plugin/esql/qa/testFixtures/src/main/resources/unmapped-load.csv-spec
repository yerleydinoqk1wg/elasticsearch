####################
# No loading tests #
####################
// Reproducer for #151525: a partially unmapped small numeric field is implicitly widened (short -> integer) without a cast.
partiallyUnmappedSmallNumericFieldIsWidened
required_capability: optional_fields_v5
required_capability: optional_fields_fix_partially_unmapped_small_numeric

SET unmapped_fields="load"\;
FROM apps_short, partial_mapping_sample_data
| KEEP id, name
| SORT name DESC NULLS LAST
| LIMIT 3
;

id:integer | name:keyword
14         | mmmmm
13         | lllll
11         | kkkkk
;

// Reproducer for #151525: explicit cast on a partially unmapped small numeric field should not throw a ClassCastException.
partiallyUnmappedSmallNumericFieldExplicitCast
required_capability: optional_fields_v5
required_capability: optional_fields_fix_partially_unmapped_small_numeric

SET unmapped_fields="load"\;
FROM all_types, all_types_no_short
| EVAL short_int = short::integer
| STATS count = COUNT(*) BY integer, short_int
| SORT integer ASC
;

count:long | integer:integer | short_int:integer
2          | 1               | 10
2          | 2               | 20
2          | 3               | 30
2          | 4               | 40
2          | 5               | 50
;

// Reproducer for #152184.
partiallyUnmappedDenseVectorIsNotAutoCast
required_capability: optional_fields_v5
required_capability: optional_fields_fix_partially_unmapped_dense_vector

SET unmapped_fields="load"\;
FROM dense_vector, dense_vector_unmapped METADATA _index
| KEEP _index, id, float_vector
| SORT _index, id
;

_index: keyword       | id:l | float_vector:dense_vector
dense_vector          | 0    | [1.0, 2.0, 3.0]
dense_vector          | 1    | [4.0, 5.0, 6.0]
dense_vector          | 2    | [9.0, 8.0, 7.0]
dense_vector          | 3    | [0.0625, 0.25, 0.75]
dense_vector          | 4    | null
dense_vector_unmapped | 0    | null
dense_vector_unmapped | 1    | null
dense_vector_unmapped | 2    | null
dense_vector_unmapped | 3    | null
dense_vector_unmapped | 4    | null
;


