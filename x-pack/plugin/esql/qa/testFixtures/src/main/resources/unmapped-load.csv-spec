required_capability: where_in_subquery_with_view

SET unmapped_fields="load"\;
FROM (FROM partial_mapping_view | WHERE message == "42" | KEEP message, unmapped_message),
     (FROM partial_mapping_view | WHERE message == "Connected to 10.1.0.3!" | KEEP message, unmapped_message)
| WHERE unmapped_message IN (FROM partial_mapping_view | WHERE message == "42" | KEEP unmapped_message)
| KEEP message, unmapped_message
| SORT message
;

message:keyword | unmapped_message:keyword
42              | 43
;
